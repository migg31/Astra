DATABASE_URL=postgresql+asyncpg://certifexpert:devpass@localhost:5433/certifexpert
DATABASE_URL_SYNC=postgresql://certifexpert:devpass@localhost:5433/certifexpert

# CORS — comma-separated list of allowed frontend origins
# CORS_ORIGINS=["http://localhost:5173","http://localhost:5174"]

# =============================================================================
# Chat LLM — reranker + answer generation
# =============================================================================

# --- Option A: Ollama local (défaut, gratuit, offline) ---
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_API_KEY=ollama
OLLAMA_MODEL=mistral

# --- Option B: Groq (gratuit, llama-3.3-70b, online) ---
# OLLAMA_BASE_URL=https://api.groq.com/openai/v1
# OLLAMA_API_KEY=<GROQ_API_KEY>       # https://console.groq.com/keys
# OLLAMA_MODEL=llama-3.3-70b-versatile

# --- Option C: OpenAI (payant) ---
# OLLAMA_BASE_URL=https://api.openai.com/v1
# OLLAMA_API_KEY=<OPENAI_API_KEY>
# OLLAMA_MODEL=gpt-4o

# =============================================================================
# Embeddings — vector generation (changing model requires re-ingestion!)
# =============================================================================

# --- Option A: Ollama local (défaut, gratuit, offline) ---
EMBED_BASE_URL=http://localhost:11434/v1
EMBED_API_KEY=ollama
EMBED_MODEL=nomic-embed-text
EMBED_DIMENSIONS=768

# --- Option B: Nomic.ai (gratuit 1M tokens/mois, meilleure qualité) ---
# EMBED_BASE_URL=https://api-atlas.nomic.ai/v1
# EMBED_API_KEY=<NOMIC_API_KEY>        # https://atlas.nomic.ai/
# EMBED_MODEL=nomic-embed-text-v1.5
# EMBED_DIMENSIONS=768

# --- Option C: OpenAI (payant, meilleure qualité) ---
# EMBED_BASE_URL=https://api.openai.com/v1
# EMBED_API_KEY=<OPENAI_API_KEY>
# EMBED_MODEL=text-embedding-3-small
# EMBED_DIMENSIONS=1536
